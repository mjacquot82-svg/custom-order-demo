# Supabase configuration (copy this file to .env and fill values)

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_public_publishable_key_here

# Optional legacy fallback if an older local env still uses the previous name.
# The app will prefer VITE_SUPABASE_PUBLISHABLE_KEY.
VITE_SUPABASE_ANON_KEY=your_supabase_public_anon_key_here
